# Copia este ficheiro para .env e preenche os valores

# Ambiente: dev ou prod
APP_ENV=dev

# URL base do site (deixa vazio se estiver na raiz do domínio)
# Exemplo XAMPP em subpasta: APP_BASE_URL=/Blog-IB
# Exemplo virtual host:      APP_BASE_URL=
APP_BASE_URL=

# Chave para criar o primeiro utilizador (acede a /setup)
# Depois de criares o utilizador, remove ou deixa vazio para desactivar /setup
APP_SETUP_KEY=muda-isto-para-uma-chave-secreta

# Base de dados MySQL
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blogib
DB_USER=root
DB_PASS=
