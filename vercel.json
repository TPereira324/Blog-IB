{
  "version": 2,
  "outputDirectory": "front-end",
  "rewrites": [
    { "source": "/articles", "destination": "/pages/articles.html" },
    { "source": "/article",  "destination": "/pages/article.html"  }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY"    }
      ]
    }
  ]
}
